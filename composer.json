{
    "name": "mohamed/shipstation-laravel",
    "description": "Laravel-first PHP client for the ShipStation API v2 (rates, labels, tracking, address validation, webhooks).",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "shipstation", "shipengine", "shipping", "labels", "tracking"],
    "authors": [
        {
            "name": "Mohamed",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "ext-json": "*",
        "illuminate/contracts": "^10.0|^11.0|^12.0",
        "illuminate/http": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Mohamed\\ShipStation\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mohamed\\ShipStation\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mohamed\\ShipStation\\ShipStationServiceProvider"
            ],
            "aliases": {
                "ShipStation": "Mohamed\\ShipStation\\Facades\\ShipStation"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
